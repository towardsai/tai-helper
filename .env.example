# Public domains where the helper widget is allowed to run.
HELPER_ALLOWED_ORIGINS=https://academy.towardsai.net,https://towardsai.net,https://www.towardsai.net
HELPER_ALLOWED_HOSTS=academy.towardsai.net,towardsai.net,www.towardsai.net

# Primary model: DeepSeek V4 Flash through OpenRouter.
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=https://towardsai.net
OPENROUTER_APP_TITLE=Towards AI Helper
HELPER_PRIMARY_MODEL=deepseek/deepseek-v4-flash

# Backup model: Gemini 2.5 Flash.
GEMINI_API_KEY=
HELPER_FALLBACK_MODEL=gemini-2.5-flash
HELPER_MAX_OUTPUT_TOKENS=420
HELPER_LLM_REQUEST_TIMEOUT_SECONDS=20

# Hard public rate limits.
HELPER_RATE_LIMIT_PER_MINUTE=3
HELPER_RATE_LIMIT_PER_DAY=20
HELPER_GLOBAL_RATE_LIMIT_PER_MINUTE=120

# Request caps.
HELPER_MAX_BODY_BYTES=65536
HELPER_MAX_QUERY_CHARS=600
HELPER_MAX_HISTORY_TURNS=8

# Optional Opik monitoring.
OPIK_ENABLED=false
OPIK_PROJECT_NAME=towards-ai-helper
OPIK_WORKSPACE=
OPIK_API_KEY=
OPIK_MAX_TEXT_CHARS=4000
